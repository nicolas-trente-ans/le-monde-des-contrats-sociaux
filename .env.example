# Default: project site at username.github.io/nicolas
VITE_BASE_PATH=/nicolas/

# Where CSV/images are fetched from (override per environment)
# Local dev uses /assets/ (served from public/assets/)
VITE_DATA_BASE_URL=/assets/

# Production example:
# VITE_DATA_BASE_URL=https://raw.githubusercontent.com/OWNER/REPO/main/assets/
