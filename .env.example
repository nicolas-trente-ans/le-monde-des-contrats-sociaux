# Default: project site at nicolas-trente-ans.github.io/le-monde-des-contrats-sociaux
VITE_BASE_PATH=/le-monde-des-contrats-sociaux/

# Where CSV/images are fetched from (override per environment)
# Local dev uses /assets/ (served from public/assets/)
VITE_DATA_BASE_URL=/assets/

# Production example:
# VITE_DATA_BASE_URL=https://raw.githubusercontent.com/nicolas-trente-ans/le-monde-des-contrats-sociaux/master/assets/
